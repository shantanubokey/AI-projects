{
  "family": "autonomous-commander",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/autonomousCommanderTaskRole",
  "containerDefinitions": [
    {
      "name": "autonomous-commander",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/autonomous-commander:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "AWS_DEFAULT_REGION", "value": "us-east-1" },
        { "name": "LOG_LEVEL", "value": "INFO" }
      ],
      "secrets": [
        {
          "name": "BEDROCK_MODEL_ID",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/autonomous-commander/bedrock-model-id"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/autonomous-commander",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
